# ============================================================
# Fazza CRM Automation API — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.
# ============================================================

# --- Database (Required) ---
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/fazza_automation

# --- JWT Auth ---
SECRET_KEY=your-super-secret-key-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Meta Webhooks (Required for IG & WA) ---
META_VERIFY_TOKEN=fazza_secure_token_change_this

# --- Instagram OAuth (Required for client self-service connection) ---
INSTAGRAM_APP_ID=your_meta_app_id
INSTAGRAM_APP_SECRET=your_meta_app_secret
INSTAGRAM_REDIRECT_URI=https://your-domain.vercel.app/api/integrations/instagram/callback

# --- Fallback tokens (Optional — only used if Channel not found in DB) ---
META_ACCESS_TOKEN=
WHATSAPP_API_TOKEN=
