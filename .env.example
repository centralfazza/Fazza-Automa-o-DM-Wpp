# ─── Banco de dados ───────────────────────────────────────────────────────────
# SQLite local (dev): sqlite:///./automation.db
# Supabase (produção): postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./automation.db

# ─── Instagram / Facebook App ─────────────────────────────────────────────────
# App ID e App Secret do seu App no developers.facebook.com
INSTAGRAM_APP_ID=seu_app_id_aqui
INSTAGRAM_APP_SECRET=seu_app_secret_aqui

# Token de verificação do Webhook (você define qualquer string)
INSTAGRAM_VERIFY_TOKEN=fazza_instagram_webhook_2024

# App Secret (mesmo que INSTAGRAM_APP_SECRET) — usado para validar assinatura HMAC do webhook
APP_SECRET=seu_app_secret_aqui

# URL de callback OAuth (deve ser registrada no painel do App Facebook)
# Em desenvolvimento: use ngrok → https://SEU_NGROK.ngrok.io/api/auth/instagram/callback
# Em produção:
INSTAGRAM_REDIRECT_URI=https://automacao-dm-ivory.vercel.app/api/auth/instagram/callback

# ─── Outras Variáveis da API ──────────────────────────────────────────────────
JWT_SECRET=seu_jwt_secret_aqui
API_BASE_URL=
PORT=8000
