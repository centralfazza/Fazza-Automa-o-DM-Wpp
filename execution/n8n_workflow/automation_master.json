        {
            "parameters": {
                "mode": "combine",
                "combinationMode": "mergeByPosition"
            },
            "name": "Merge Triggers",
            "type": "n8n-nodes-base.merge",
            "typeVersion": 2,
            "position": [
                0,
                250
            ],
            "id": "merge"
        },
        {
            "parameters": {
                "jsCode": "function sanitizeValue(value) {\n  if (value === null || value === undefined) return '';\n  if (typeof value === 'object') {\n    const obj = {};\n    for (const key in value) obj[key] = sanitizeValue(value[key]);\n    return obj;\n  }\n  let str = String(value).trim();\n  str = str.replace(/\\s{2,}/g, ' ');\n  str = str.replace(/[<>`$\\\\{}]/g, '');\n  return str;\n}\n\nconst body = $input.first().json.body || {};\nconst nodeName = $node[\"Merge Triggers\"].name;\n\nlet trigger_type = \"\";\nif (nodeName.includes(\"Follower\")) trigger_type = \"follower\";\nelse if (nodeName.includes(\"DM\")) trigger_type = \"dm_received\";\nelse if (nodeName.includes(\"Comment\")) trigger_type = \"comment\";\nelse if (nodeName.includes(\"Mention\")) trigger_type = \"story_mention\";\nelse if (nodeName.includes(\"Reply\")) trigger_type = \"story_reply\";\n\nreturn [{\n  json: {\n    trigger_type,\n    instagram_account_id: sanitizeValue(body.instagram_account_id),\n    sender_username: sanitizeValue(body.follower_username || body.sender_username || body.commenter_username).replace('@', ''),\n    message_text: sanitizeValue(body.message_text || body.comment_text || body.reply_text),\n    sender_id: sanitizeValue(body.follower_id || body.sender_id || body.commenter_id),\n    post_id: sanitizeValue(body.post_id),\n    story_id: sanitizeValue(body.story_id),\n    comment_id: sanitizeValue(body.comment_id)\n  }\n}];"
            },
            "name": "Sanitize Input",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                150,
                250
            ],
            "id": "sanitize"
        },
        {
            "parameters": {
                "method": "GET",
                "url": "={{ $env.BACKEND_URL }}/api/integrations/companies/by-instagram-account/{{ $json.instagram_account_id }}",
                "sendHeaders": true,
                "headerParameters": {
                    "parameters": [
                        {
                            "name": "Authorization",
                            "value": "=Bearer {{ $env.API_TOKEN }}"
                        }
                    ]
                }
            },
            "name": "Get Company Info",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.1,
            "position": [
                500,
                250
            ],
            "id": "get_company"
        },
        {
            "parameters": {
                "method": "GET",
                "url": "={{ $env.BACKEND_URL }}/api/automations/match",
                "sendQueryParameters": true,
                "queryParameters": {
                    "parameters": [
                        {
                            "name": "company_id",
                            "value": "={{ $node[\"Get Company Info\"].json.id }}"
                        },
                        {
                            "name": "trigger_type",
                            "value": "={{ $node[\"Sanitize Input\"].json.trigger_type }}"
                        },
                        {
                            "name": "message",
                            "value": "={{ $node[\"Sanitize Input\"].json.message_text }}"
                        },
                        {
                            "name": "sender",
                            "value": "={{ $node[\"Sanitize Input\"].json.sender_username }}"
                        },
                        {
                            "name": "platform",
                            "value": "instagram"
                        }
                    ]
                }
            },
            "name": "Match Automation",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.1,
            "position": [
                750,
                250
            ],
            "id": "match"
        },
        {
            "parameters": {
                "conditions": {
                    "boolean": [
                        {
                            "value1": "={{ !!$json.id }}",
                            "value2": true
                        }
                    ]
                }
            },
            "name": "Found Automation?",
            "type": "n8n-nodes-base.if",
            "typeVersion": 1,
            "position": [
                1000,
                250
            ],
            "id": "if_active"
        },
        {
            "parameters": {
                "fieldToSplitOut": "actions"
            },
            "name": "Execute Actions",
            "type": "n8n-nodes-base.itemLists",
            "typeVersion": 3,
            "position": [
                1150,
                150
            ],
            "id": "loop"
        },
        {
            "parameters": {
                "jsCode": "const automation = $node[\"Match Automation\"].json;\nconst company = $node[\"Get Company Info\"].json;\nconst webhook = $node[\"Sanitize Input\"].json;\n\nconst variables = {\n  name: webhook.sender_username,\n  username: webhook.sender_username,\n  company: company.name,\n  time: new Date().toLocaleString('pt-BR', {\n    timeZone: 'America/Sao_Paulo',\n    hour: '2-digit',\n    minute: '2-digit'\n  })\n};\n\nlet processedMessage = $json.content || \"\";\nObject.keys(variables).forEach(key => {\n  processedMessage = processedMessage.replace(new RegExp(`\\\\{${key}\\\\}`,'g'), variables[key]);\n});\n\nreturn [{ json: { ...$json, processed_message: processedMessage, company, webhook, automation } }];"
            },
            "name": "Process Variables",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                1350,
                150
            ],
            "id": "process_vars"
        },
        {
            "parameters": {
                "dataType": "string",
                "value1": "={{ $json.type }}",
                "rules": {
                    "rules": [
                        {
                            "value2": "send_dm"
                        },
                        {
                            "value2": "add_tag"
                        },
                        {
                            "value2": "delay"
                        },
                        {
                            "value2": "webhook"
                        }
