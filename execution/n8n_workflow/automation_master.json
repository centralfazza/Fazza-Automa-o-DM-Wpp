                        }
                    ]
                }
            },
            "name": "External Webhook",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.1,
            "position": [
                1800,
                460
            ],
            "id": "ext_webhook"
        },
        {
            "parameters": {
                "jsCode": "const now = new Date().toLocaleString('pt-BR', {\n  timeZone: 'America/Sao_Paulo',\n  day: '2-digit', month: '2-digit', year: 'numeric',\n  hour: '2-digit', minute: '2-digit', second: '2-digit'\n});\n\nreturn [{\n  json: {\n    company_id: $json.company.id,\n    automation_id: $json.automation.id,\n    recipient: $json.webhook.sender_username,\n    success: true,\n    executed_at: now,\n    automation_name: $json.automation.name\n  }\n}];"
            },
            "name": "Format Log Data",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                2200,
                250
            ],
            "id": "format_log"
        },
        {
